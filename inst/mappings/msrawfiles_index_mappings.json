{
  "mappings": {
    "_meta": {
      "type": "ntsportal,msrawfiles",
      "version": "25.3",
      "licence": "GNU GPL-3.0"
    },
    "dynamic": "strict",
    "properties": {
      "blank": {"type": "boolean", "meta": {"description": "Is sample a blank?"}},
      "blank_regex": {"type": "keyword", "meta": {"description": "Regex. for blank code in filename"}},
      "chrom_method": {"type": "keyword", "meta": {"description": "chromatographic method code", "example": "bfg_nts_rp1"}},
      "comment": {"type": "text", "meta": {"description": "free as text or array of text blocks"}},
      "csl_instruments_allowed": {"type": "keyword", "meta": {"description": "Allowed instruments for library spectra"}},
      "data_source": {"type": "keyword", "meta": {"description": "institution responsible for data processing", "example": "bfg"}},
      "date_import": {"type": "date", "format": "epoch_second", "meta": {"description": "DEPRECATED, use date_ingest"}},
      "date_ingest": {"type": "date", "format": "yyyy-MM-dd HH:mm:ss", "meta": {"description": "ingest time"}},
      "date_measurement": {"type": "date", "format": "yyyy-MM-dd HH:mm:ss", "meta": {"description": "instrumental analysis time"}},
      "dbas_area_threshold": {"type": "integer", "meta": {"description": "Minimum area of EIC peak"}},
      "dbas_blank_int_factor": {"type": "integer", "meta": {"description": "Blank correction max. inten. ratio (sample/blank)"}},
      "dbas_date_format": {"type": "keyword",  "meta": {"description": "DEPRECATED", "example": "ymd"}},
      "dbas_date_regex": {"type": "keyword", "meta": {"description": "DEPRECATED", "example": "Des_(\\d{2})_"}},
      "dbas_fp": {"type": "keyword", "meta": {"description": "Compounds removed from peaklist (false positives)"}},
      "dbas_is_name": {"type": "keyword", "meta": {"description": "DEPRECATED use internal_standard", "example": "Bezafibrate-d6"}},
      "dbas_is_table": {"type": "keyword", "meta": {"description": "Path to int. std. table (CSV)"}},
      "dbas_mztolu": {"type": "float", "meta": {"description": "m/z tol. for library matching (1st round/rough)", "unit": "Da"}},
      "dbas_mztolu_fine": {"type": "float", "meta": {"description": "m/z tol. for library matching", "unit": "Da"}},
      "dbas_ndp_threshold": {"type": "integer", "meta": {"description": "Min. dot product MS2 match to library (0-1000)"}},
      "dbas_ndp_m": {"type": "integer", "meta": {"description": "Peak inten. weighting factor for dot product"}},
      "dbas_ndp_n": {"type": "integer", "meta": {"description": "m/z weighting factor for dot product"}},
      "dbas_instr": {"type": "keyword", "meta": {"description": "DEPRECATED use csl_instruments_allowed"}},
      "dbas_blank_regex": {"type": "keyword", "meta": {"description": "DEPRECATED use blank_regex"}},
      "dbas_minimum_detections": {"type": "integer", "meta": {"description": "Minimum MS2 matches in batch (otherwise FP)"}},
      "dbas_replicate_regex": {"type": "keyword", "meta": {"description": "DEPRECATED", "example": "(_)[123]_"}},
      "dbas_rttolm": {"type": "float", "meta": {"description": "Ret. time tol. for library match", "unit": "min"}},
      "dbas_rtTolReinteg": {"type": "float", "meta": {"description": "Ret. time tol. for reingetration (gap filling)"}},
      "dbas_station_regex": {"type": "keyword", "meta": {"description": "Sampling location code from filename"}},
      "duration": {"type": "keyword", "meta": {"description": "Composite sample duration (ISO 8601) grab: P0", "example": "P1Y"}},
      "feature_table_alias": {"type": "keyword", "meta": {"description": "Alias to use for feature table", "example": "ntsp25.3_feature_bfg"}},
      "filesize": {"type": "float", "meta": {"description": "Meas. file size", "unit": "MB"}}, 
      "gkz": { "type": "integer", "meta": {"description": "gewaesserkennzahl of sampling location", "example": "26"}},
      "instrument": { "type": "keyword", "meta": {"description": "instrument type code", "example": "LC-ESI-QTOF TripleTOF 6600 SCIEX"}},
      "internal_standard": {"type": "keyword", "meta": {"description": "Internal standard used in processing", "example": "Bezafibrate-d6"}},
      "km": { "type": "float", "meta": {"description": "river kilometer of sampling location"}},
      "licence": {"type": "keyword", "meta": {"description": "open data licence for data", "example": "dl-de/by-2-0"}},
      "loc": {"type": "geo_point", "meta": {"description": "Sampling coordinates (WGS84)"}},
      "matrix": {"type": "keyword", "meta": {"description": "Sampling matrix code", "example": "spm"}},
      "nts_mz_min": {"type": "float", "meta": {"description": "Peak-picking lower m/z limit", "unit": "Da"}},                                    
      "nts_mz_max": {"type": "float", "meta": {"description": "Peak-picking upper m/z limit", "unit": "Da"}},                                    
      "nts_mz_step": {"type": "float", "meta": {"description": "Peak-picking EIC binning width", "unit": "Da"}},                                   
      "nts_rt_min": {"type": "float", "meta": {"description": "Peak-picking lower ret. time limit", "unit": "min"}},                                     
      "nts_rt_max": {"type": "float", "meta": {"description": "Peak-picking upper ret. time limit", "unit": "min"}},                                    
      "nts_sn": {"type": "float", "meta": {"description": "Peak-picking lower S/N limit"}},
      "nts_int_threshold": {"type": "float", "meta": {"description": "Peak-picking lower EIC peak apex intensity limit"}},
      "nts_peak_noise_scans": {"type": "float", "meta": {"description": "Peak-picking scans around peak to detect noise"}},
      "nts_precursor_mz_tol": {"type": "float", "meta": {"description": "Peak-picking m/z tol. to find MS2 precursor", "unit": "ppm"}},                          
      "nts_peak_width_min": {"type": "float", "meta": {"description": "Peak-picking max. EIC peak width at baseline", "unit": "s"}},                             
      "nts_peak_width_max": {"type": "float", "meta": {"description": "Peak-picking min. EIC peak width at baseline", "unit": "s"}},                             
      "nts_max_num_peaks": {"type": "float", "meta": {"description": "Peak-picking max. subpeaks/noise within EIC peak"}},
      "nts_alig_delta_mz": {"type": "float", "meta": {"description": "Alignment m/z tol. within batch", "unit": "mDa"}},                             
      "nts_alig_delta_rt": {"type": "float", "meta": {"description": "Alignment ret. time tol. within batch", "unit": "s"}},                             
      "nts_alig_filter_type": {"type": "keyword", "meta": {"description": "Alig. tab. filter type", "example": "consecutive/replicate/min_features"}},                 
      "nts_alig_filter_num_consecutive": {"type": "byte", "meta": {"description": "Min. consecutive detections"}},
      "nts_alig_filter_min_features": {"type": "byte", "meta": {"description": "Min. detections per replicate set"}},          
      "nts_annotation_threshold_dp_score": {"type": "short", "meta": {"description": "Min. dot product MS2 match to library (0-1000)"}},                  
      "nts_annotation_mz_tol": {"type": "float", "meta": {"description": "Min. m/z match to library", "unit": "mDa"}},                            
      "nts_annotation_rt_tol": {"type": "float", "meta": {"description": "Min. ret. time match to library", "unit": "min"}},                          
      "nts_annotation_ce_min": {"type": "short", "meta": {"description": "Min. collision energy of library spectra"}},
      "nts_annotation_ce_max": {"type": "short", "meta": {"description": "Max. collision energy of library spectra"}},
      "nts_annotation_ces_min": {"type": "short", "meta": {"description": "Min. collision energy spread of library spectra"}},
      "nts_annotation_ces_max": {"type": "short", "meta": {"description": "Max. collision energy spread of library spectra"}},
      "nts_annotation_ms2_mz_tol": {"type": "float", "meta": {"unit": "mDa"}},                       
      "nts_annotation_rt_offset": {"type": "float", "meta": {"unit": "min", "method": "Offset added to DB RT"}},                        
      "nts_annotation_int_cutoff": {"type": "float", "meta": {"description": "Rel. inten. cutoff of data MS2 when matching"}},
      "nts_componentization_ppm": {"type": "float", "meta": {"description": "Known components m/z diff., ppm tol."}},
      "nts_componentization_rt_tol": {"type": "float", "meta": {"description": "Peak apex ret. time tol.", "unit": "s"}},                  
      "nts_componentization_rt_tol_l": {"type": "float", "meta": {"description": "Peak ret. time at half-height left, tol.", "unit": "s"}},                 
      "nts_componentization_rt_tol_r": {"type": "float", "meta": {"description": "Peak ret. time at half-height right, tol.", "unit": "s"}},                 
      "nts_componentization_rt_tol_sum": {"type": "float", "meta": {"description": "Peak three point ret. time sum, tol.", "unit": "s"}},                
      "nts_componentization_dynamic_tolerance": {"type": "boolean", "meta": {"description": "Compute componentization tol. using 13C peak"}},
      "nts_componen2_mz_tol": {"type": "float", "meta": {"description": "Future use", "unit": "mDa"}},                          
      "nts_componen2_rt_tol": {"type": "float", "meta": {"description": "Future use", "unit": "s"}},                           
      "nts_componen2_frac_shape": {"type": "float", "meta": {"description": "Future use", "description": ""}},                       
      "nts_componen2_correlation": {"type": "float", "meta": {"description": "Future use", "method": "Pearson"}},                       
      "nts_blank_correction_factor": {"type": "float", "meta": {"description": "Alig. tab. filter max. inten. ratio (sample/blank)"}},
      "nts_eic_extraction_width": {"type": "float", "meta": {"description": "Sample tab. opt. EIC m/z width", "unit": "mDa"}},                        
      "path": {"type": "keyword", "meta": {"description": "Absolute path to measurement file (mzXML, mzML)"}},
      "pol": {"type": "keyword", "meta": {"description": "3-letter ESI polarity mode", "example": "pos"}},
      "replicate_regex": {"type": "keyword", "meta": {"description": "Regular expression to group files into replicates", "example": "(_)[123]_"}},
      "river": { "type": "keyword", "meta": {"description": "river name of sampling location (local spelling)", "example": "rhein"}},
      "sample_source": {"type": "keyword", "meta": {"description": "institute responsible for sampling", "example": "bful/lfulg saxony"}},
      "spectral_library_path": {"type": "keyword", "meta": {"description": "Path to spectral library (CSL) SQLite file"}},
      "start": {"type": "date", "format": "yyyy-MM-dd HH:mm:ss||yyyy-MM-dd||yyyy-MM-dd HH:mm", "meta": {"description": "Start of sampling in UTC"}},
      "start_date_format": {"type": "keyword",  "meta": {"description": "Format of date in filename", "example": "ymd"}},
      "start_date_regex": {"type": "keyword", "meta": {"description": "Regex. for date in filename, date in brackets", "example": "Des_(\\d{2})_"}},
      "station": {"type": "keyword", "meta": {"description": "Sampling location code", "example": "rhein_ko_l"}},
      "tag": {"type": "keyword", "meta": {"description": "Labels to assist searching"}}
    },
    "runtime": {
      "filename": {
        "type": "keyword",
        "script": "def x=params._source.path.splitOnToken('/'); emit(x[x.length-1])",
        "meta": {"description": "Basename of path field", "example": "KO_06_1_pos.mzXML"}
      },
      "batchname": {
        "type": "keyword",
        "script": "def x = params._source.path.splitOnToken('/'); emit(String.join('/', Arrays.asList(x).subList(0,x.length-1)))",
        "meta": {"description": "Leading directories of path field", "example": "/beegfs/nts/ntsportal/msrawfiles/unit_tests"}
      }
    }
  }
}